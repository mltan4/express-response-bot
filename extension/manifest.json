{
  "manifest_version": 3,
  "name": "ReplyKit for LinkedIn",
  "version": "1.0.0",
  "description": "Generate on-brand LinkedIn replies and post comments in one click. Works in Chrome, Edge, Brave, Arc, and Opera.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://qrgtlojcgbnptdorloro.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://*.lovable.app/*",
      "https://*.lovableproject.com/*",
      "https://replykit.nextcraft.life/*",
      "https://*.nextcraft.life/*",
      "http://localhost/*",
      "http://localhost:*/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon.png"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
